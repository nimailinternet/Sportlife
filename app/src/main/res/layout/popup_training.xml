<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#3F3F3F"
    android:padding="16dp"
    android:elevation="10dp">

    <!-- Заголовок дня -->
    <TextView
        android:id="@+id/popup_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Понедельник"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Строка с временем и кнопками -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <!-- Кнопка Карандаш (Редактировать) -->
        <ImageButton
            android:id="@+id/btn_edit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Редактировать"
            app:tint="#FFFFFF"
            android:padding="12dp"/>

        <!-- Время -->
        <EditText
            android:id="@+id/tv_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="19:00"
            android:textColorHint="#FFFFFF"
            android:textSize="18sp"
            android:gravity="center"/>

        <!-- Кнопка Корзина (Удалить) -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Удалить"
            app:tint="#FF5252"
            android:padding="12dp"/>
    </LinearLayout>

    <!-- Кнопка плюса (Добавить тренировку) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/popup_add"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="+"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:backgroundTint="#D3D3D3"
        app:cornerRadius="8dp"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

</LinearLayout>