<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/MainBackground"
    android:id="@+id/activityExerciseDetail">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="?attr/SubBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name_part1"
            style="@style/nameAppLeft"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name_part2"
            style="@style/nameAppRight"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExerciseTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                style="@style/secondTitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding"
                android:background="?attr/SubBackground"
                android:layout_marginBottom="@dimen/margin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/tab_technique"
                        style="@style/subTitle"/>

                    <ImageView
                        android:id="@+id/chkFavorite"
                        android:layout_width="@dimen/imgSub"
                        android:layout_height="@dimen/imgSub" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTechnique"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="1. Хват: Возьмитесь за перекладину хватом чуть шире плеч, ладони направлены от себя.\n\n2. Вис: Полностью выпрямите руки, расслабьте плечи, но сохраняйте активное напряжение в лопатках.\n\n3. Подъем: На выдохе плавно подтянитесь вверх, сводя лопатки и стремясь коснуться перекладины верхней частью груди. Локти должны двигаться вниз к корпусу.\n\n4. Пик: В верхней точке задержитесь на секунду, подбородок должен оказаться выше перекладины.\n\n5. Спуск: Подконтрольно опуститесь вниз до полного выпрямления рук."
                    style="@style/exerciseText"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/SubBackground"
                android:padding="@dimen/padding"
                android:layout_marginBottom="@dimen/margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_video"
                    style="@style/subTitle" />

                <WebView
                    android:id="@+id/videoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    tools:ignore="WebViewLayout">
                </WebView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/SubBackground"
                android:padding="@dimen/padding"
                android:layout_marginBottom="@dimen/margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_equipment"
                    style="@style/subTitle" />

                <TextView
                    android:id="@+id/tvEquipment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    style="@style/exerciseText"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/SubBackground"
                android:padding="@dimen/padding"
                android:layout_marginBottom="@dimen/margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_muscle_groups"
                    style="@style/subTitle" />

                <TextView
                    android:id="@+id/tvMuscle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    style="@style/exerciseText"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding"
        android:background="?attr/SubBackground">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:text="@string/btn_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/buttonBack"/>
    </LinearLayout>

</LinearLayout>