<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="nameAppLeft" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">@dimen/Title</item>
        <item name="android:text">Sport-</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="nameAppRight" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/Title</item>
        <item name="android:text">life</item>
    </style>
    <style name="secondTitle" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">@dimen/SecondTitle</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="EditName" parent="Widget.AppCompat.EditText">
        <item name="android:textColorHint">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:hint">Name:</item>
        <item name="android:background">@drawable/profile_field_bg</item>
        <item name="android:textSize">@dimen/editText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/padding</item>
    </style>
    <style name="EditPassword" parent="Widget.AppCompat.EditText">
        <item name="android:textColorHint">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:hint">Password:</item>
        <item name="android:background">@drawable/profile_field_bg</item>
        <item name="android:textSize">@dimen/editText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/padding</item>
    </style>
    <style name="errorText" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">@dimen/subText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/red</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="buttonMain" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/button_green_rounded</item>
        <item name="backgroundTint">#00B7B7</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/padding</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/buttonText</item>
    </style>
    <style name="subNavigation" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/whitedGray</item>
        <item name="android:textSize">@dimen/Text</item>
        <item name="android:textStyle">normal</item>
        <item name="android:layout_gravity">center</item>
    </style>
    <style name="subTitle" parent="Widget.AppCompat.TextView">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/subTitle</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="ButtonNavigation" parent="Widget.Material3.Button">
        <item name="android:textSize">@dimen/navigationButton</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/blue</item>
        <item name="cornerRadius">@dimen/navigationRadius</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="cardTop">
        <item name="android:textColor">@color/blackedWhite</item>
        <item name="android:padding">@dimen/padding</item>
        <item name="android:gravity">center_vertical</item>
        <item name="cardCornerRadius">@dimen/CardRadius</item>
        <item name="android:background">@color/blackedWhite</item>
        <item name="android:orientation">horizontal</item>
    </style>
    <style name="mainText" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/Text</item>
    </style>
    <style name="subText" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/graySecond</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/subText</item>
    </style>
    <style name="levelButton">
        <item name="android:textSize">@dimen/levelText</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:background">@drawable/level_button_selector</item>
    </style>
    <style name="buttonBack" parent="Widget.Material3.Button">
        <item name="android:text">Назад</item>
        <item name="android:textSize">@dimen/navigationButton</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/grayBack</item>
        <item name="cornerRadius">@dimen/navigationRadius</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="muscle">
        <item name="android:stateListAnimator">@animator/mtrl_btn_unelevated_state_list_anim</item>
        <item name="elevation">0dp</item>
        <item name="android:padding">@dimen/musclePadding</item>
        <item name="android:background">@drawable/muscle_zone_selector</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/muscleName</item>
        <item name="android:textStyle">bold</item>
        <item name="android:visibility">visible</item>
    </style>
    <style name="page">
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:text">1</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="cardView">
        <item name="android:background">@drawable/level_button_selector</item>
        <item name="cardCornerRadius">@dimen/CardRadius</item>
        <item name="android:textColor">@color/blackedWhite</item>
        <item name="android:padding">@dimen/padding</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>
    <style name="exerciseText">
        <item name="android:textSize">@dimen/Text</item>
        <item name="android:textColor">@color/blackedWhite</item>
        <item name="android:textStyle">normal</item>
    </style>
</resources>