<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Состояние "Выбрано" -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="#4CAF50"/> <!-- Зеленая рамка -->
            <corners android:radius="8dp"/>
            <solid android:color="#404CAF50"/> <!-- Полупрозрачный зеленый фон -->
        </shape>
    </item>
    <!-- Состояние "Обычное" -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="#FF5722"/> <!-- Оранжевая рамка -->
            <corners android:radius="8dp"/>
            <solid android:color="#00000000"/> <!-- Прозрачный -->
        </shape>
    </item>
</selector>